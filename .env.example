# =============================================================================
# Perseus Vault — environment template.
# Copy to `.env` and fill in real values. NEVER commit `.env` (it is gitignored).
# =============================================================================

# --- CockroachDB (application connection, used by psycopg2) -------------------
# CockroachDB Cloud gives you this string in the "Connect" dialog.
DATABASE_URL="postgresql://<user>:<password>@<host>:26257/<database>?sslmode=verify-full&sslrootcert=<path-to-ca.crt>"

# Embedding vector dimension. MUST match the schema (db_schema.py) and provider:
#   Amazon Bedrock Titan v2 -> 1024   |   OpenAI text-embedding-3-small -> 1536
EMBEDDING_DIMENSION=1024

# Optional: cluster name for the `ccloud` CLI (advisory health checks only).
CCLOUD_CLUSTER_NAME="<your-cluster-name>"

# Optional: logical agent identity (namespaces memories for cross-session recall).
AGENT_ID="perseus-vault-demo-bedrock"

# --- CockroachDB MCP Server (github.com/amineelkouhen/mcp-cockroachdb) --------
# These power the required CockroachDB MCP Server integration (see mcp_config.json).
# Point them at the SAME cluster as DATABASE_URL.
CRDB_HOST="<host>"
CRDB_PORT="26257"
CRDB_DATABASE="<database>"
CRDB_USERNAME="<user>"
CRDB_PWD="<password>"
CRDB_SSL_MODE="verify-full"
CRDB_SSL_CA_PATH="<path-to-ca.crt>"

# --- AWS (Bedrock embeddings + Lambda runtime) -------------------------------
AWS_REGION="us-east-1"
BEDROCK_EMBEDDING_MODEL="amazon.titan-embed-text-v2:0"
# AWS credentials are read from the standard chain (~/.aws/credentials, instance
# role, or the vars below). On Lambda, prefer an execution role over static keys.
# AWS_ACCESS_KEY_ID="<access-key>"
# AWS_SECRET_ACCESS_KEY="<secret-key>"

# --- OpenAI (fallback embedding provider) ------------------------------------
# Only needed if you run the OpenAI variant (agent.py) instead of Bedrock.
# OPENAI_API_KEY="sk-..."
# OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# --- Recall-ranking / decay tunables (optional; sane defaults in vault_core) --
# RANK_W_SIMILARITY=0.60
# RANK_W_RECENCY=0.25
# RANK_W_FREQUENCY=0.15
# RECENCY_HALFLIFE_DAYS=7.0
# DECAY_RATE=0.05
# DECAY_THRESHOLD=0.20
# REINFORCE_BOOST=0.15
